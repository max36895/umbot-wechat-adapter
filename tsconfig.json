{
    "compilerOptions": {
        "module": "Node16",
        "target": "ES2023",
        "moduleResolution": "Node16",
        "declaration": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "forceConsistentCasingInFileNames": true,
        "newLine": "LF"
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "tests"]
}
